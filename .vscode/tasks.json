{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MPI",
            "type": "shell",
            "command": "mpicc",
            "args": [
                "-g",
                "-O0",
                "exercise.c",
                "-o",
                "exercise"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: mpicc build active file",
            "command": "/usr/bin/mpicc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}